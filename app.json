{
  "expo": {
    "name": "Xentra",
    "slug": "xentra",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icons/app-icon.png",
    "scheme": "xentra",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/icons/app-icon.png",
      "bundleIdentifier": "com.xentra.xentra",
      "supportsTablet": true,
      "infoPlist": {
        "UIBackgroundModes": ["remote-notification", "fetch"],
        "NSCameraUsageDescription": "Xentra needs access to your camera to take photos for your profile picture.",
        "NSPhotoLibraryUsageDescription": "Xentra needs access to your photo library to select existing photos for your profile picture.",
        "NSPhotoLibraryAddUsageDescription": "Xentra needs access to save photos to your photo library."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/icons/app-icon.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/logo-glow.png"
      },
      "package": "com.xentra.xentra",
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.SCHEDULE_EXACT_ALARM",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.VIBRATE",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/icons/logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "image": "./assets/icons/logo.png",
            "backgroundColor": "#ffffff"
          }
        }
      ],
      [
        "expo-image",
        {
          "disableLibdav1d": true
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Xentra to access your camera to take photos for your profile picture.",
          "microphonePermission": "Allow Xentra to access your microphone to record videos for your profile picture.",
          "recordAudioAndroid": true,
          "barcodeScannerEnabled": true
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icons/notification-icon.png",
          "color": "#208AEF",
          "defaultChannel": "default",
          "enableBackgroundRemoteNotifications": true,
          "sounds": ["./assets/media/notification_sound.wav"]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "40130228-1a81-42aa-95e8-4ed5c1608014"
      }
    }
  }
}
